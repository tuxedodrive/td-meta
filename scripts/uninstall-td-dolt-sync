#!/usr/bin/env bash
# ABOUTME: Removes the td-dolt-sync launchd agent installed by install-td-dolt-sync.
# ABOUTME: Leaves the script + log file in place; safe to re-install afterwards.

set -euo pipefail

LABEL="com.tuxedodrive.td-dolt-sync"
PLIST_PATH="$HOME/Library/LaunchAgents/$LABEL.plist"

launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true
rm -f "$PLIST_PATH"

echo "Removed launchd agent: $LABEL"
echo "  plist removed:   $PLIST_PATH"
echo "  script retained: $(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/td-dolt-sync"
